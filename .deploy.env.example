# Rep Legend Deploy Config
# Copy this file to .deploy.env and fill in your values
# .deploy.env is gitignored — never commit it

SERVER_HOST="your-server-ip-or-domain.com"
SERVER_USER="root"                          # or your SSH username
SERVER_PATH="/var/www/rep-legend"           # remote directory to deploy to
SSH_KEY="~/.ssh/id_rsa"                     # path to your SSH private key (leave blank to use default)
